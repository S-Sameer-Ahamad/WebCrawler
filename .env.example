# Required — crawl requests fail with 503 if missing
SAAS_BACKEND_URL=https://your-saas-backend-url.com
CRAWLER_INTERNAL_TOKEN=replace_with_saas_internal_token
CRAWLER_API_TOKEN=replace_with_crawler_api_token

# Backend send tuning
MAX_BACKEND_SEND_CONCURRENCY=3
MAX_BACKEND_FAILURE_RATE=0.8
MIN_SEND_ATTEMPTS_BEFORE_ABORT=5

# Job lifecycle
JOB_TTL_SECONDS=7200
MAX_ACTIVE_JOBS=10

# Server
PORT=8765
HOST=0.0.0.0
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# CORS (comma-separated, * for all)
CORS_ORIGINS=*
